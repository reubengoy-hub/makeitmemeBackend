<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Make It Meme"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etServerIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="IP del Servidor (ej. 192.168.1.100)"
        android:layout_marginBottom="16dp"
        android:inputType="textUri" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conectar al Servidor"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/etPlayerName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tu Nombre"
        android:layout_marginBottom="16dp"
        android:inputType="textPersonName" />

    <EditText
        android:id="@+id/etRoomCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Código de Sala (si te unes)"
        android:layout_marginBottom="24dp"
        android:inputType="textCapCharacters" />

    <Button
        android:id="@+id/btnJoinRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unirse a Partida"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnCreateRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear Nueva Partida" />

</LinearLayout>
